  Name: Table
  m_nodes:
  - Name: Table
    Text: "Ma\xE9, si tu veux Otto a trouv\xE9 une ancienne bo\xEEte de vinyles \xE0
      la brocante du quartier, tu peux aller la chercher\u202F?"
    Actor: {fileID: 11400000, guid: bbfb9a7d1baed1837ae043f229a9db6e, type: 2}
    ActorSprite: 0
    Behavior: 0
  - Name: Table
    Text: "Tu n\u2019peux pas la manquer, c\u2019est la <color=green>seule</color>
      sous l\u2019\xE9tabli, \xE0 c\xF4t\xE9 d\u2019une flight case."
    Actor: {fileID: 11400000, guid: bbfb9a7d1baed1837ae043f229a9db6e, type: 2}
    ActorSprite: 1
    Behavior: 0
